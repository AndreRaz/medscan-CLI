# Configuración de medscan
# Copia este archivo como .env y rellena los valores

# ─── Proveedor de LLM ─────────────────────────────────────────────────────────
# Opciones: "gemini" (gratis, desarrollo) | "anthropic" (producción)
MEDISCAN_PROVIDER=gemini

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Gemini: obtén gratis en https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=AIzaSy_TU_KEY_AQUI

# Anthropic: obtén en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-TU_KEY_AQUI

# ─── Modelos ──────────────────────────────────────────────────────────────────
MEDISCAN_GEMINI_MODEL=gemini-2.5-flash
MEDISCAN_ANTHROPIC_MODEL=claude-opus-4-5

# ─── Base de datos ────────────────────────────────────────────────────────────
MEDISCAN_DB_PATH=./mediscan.db

# ─── Pre-procesamiento de imagen ──────────────────────────────────────────────
# Ancho máximo en píxeles antes de enviar a la API (reduce tokens)
MEDISCAN_MAX_WIDTH=1200

# Factor de contraste (1.0 = sin cambio, 1.3 = ligeramente aumentado)
MEDISCAN_CONTRAST=1.3

# Varianza mínima para aceptar una imagen (0 = desactiva detección de blur)
# Referencia: nítida > 200, ligeramente movida 80-150, muy borrosa < 80
MEDISCAN_BLUR_THRESHOLD=100.0

# ─── Logging ──────────────────────────────────────────────────────────────────
# Opciones: debug | info | warn | error
MEDISCAN_LOG_LEVEL=info
